# ============================================
# Email Configuration
# ============================================
# IMPORTANT: Copy .env.local.example to .env.local and add real credentials there
# .env.local is gitignored and will not be committed
SMTP_HOST=mail.b.hostedemail.com
SMTP_PORT=465
SMTP_USER=info@yannova.be
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE  # Get from email hosting provider

# ============================================
# NextAuth Configuration
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR_AUTH_SECRET_HERE  # Add real secret to .env.local
AUTH_URL=http://localhost:3000  # Override in production with NEXT_PUBLIC_SITE_URL

# ============================================
# Database - Supabase PostgreSQL
# ============================================
# Get credentials from Supabase dashboard
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.nnlekbywldrainqhvgif.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD_HERE@db.nnlekbywldrainqhvgif.supabase.co:5432/postgres?schema=public"

# ============================================
# Google AI & Analytics
# ============================================
# Google Analytics ID (public - safe to commit)
NEXT_PUBLIC_GA_ID=G-1RS27QF82W
# Get API key from Google Cloud Console
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_AI_API_KEY_HERE  # Add real key to .env.local

# ============================================
# Supabase (optional - for file storage)
# ============================================
# Get these keys from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://nnlekbywldrainqhvgif.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE  # Add real key to .env.local
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE  # Add real key to .env.local

# ============================================
# Site Configuration
# ============================================
# For local development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production, set in Vercel: NEXT_PUBLIC_SITE_URL=https://www.yannova.be
