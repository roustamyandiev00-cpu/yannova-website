# ============================================
# TEMPLATE - Kopieer naar .env.local en vul echte waarden in
# .env.local is gitignored en wordt NOOIT gecommit
# ============================================

# Email Configuration
SMTP_HOST=mail.b.hostedemail.com
SMTP_PORT=465
SMTP_USER=info@yannova.be
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE

# NextAuth Configuration
# Genereer met: openssl rand -base64 32
AUTH_SECRET=YOUR_AUTH_SECRET_HERE
AUTH_URL=http://localhost:3000

# Database - Supabase PostgreSQL
DATABASE_URL="postgres://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgres://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/postgres?sslmode=require"

# Google AI & Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MICROSOFT_UET_ID=YOUR_UET_ID
NEXT_PUBLIC_GOOGLE_ADS_ID=YOUR_ADS_ID
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_AI_API_KEY_HERE

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET_HERE

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.yannova.be

# Admin setup secret
ADMIN_SETUP_SECRET=YOUR_STRONG_SECRET_HERE

# Datadog APM
DD_API_KEY=YOUR_DD_API_KEY
DD_SITE=datadoghq.eu
DD_SERVICE=yannova
DD_ENV=production
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=YOUR_RUM_APP_ID
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=YOUR_RUM_CLIENT_TOKEN
