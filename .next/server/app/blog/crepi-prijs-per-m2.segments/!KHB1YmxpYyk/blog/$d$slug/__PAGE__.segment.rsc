$","h1",null,{"className":"text-4xl font-bold text-white sm:text-5xl","children":"Crepi prijs per m²: wat kost gevelbepleistering in 2026?"}],["$","p",null,{"className":"mt-6 text-xl leading-relaxed text-gray-300","children":"De prijs van crepi hangt sterk af van wat er onder zit. Enkel crepi op een bestaande gevel is een heel ander verhaal dan een volledig ETICS-systeem met isolatieplaten. In deze gids zetten we de prijsblokken op een rij."}],["$","div",null,{"className":"mt-6 flex items-center gap-4 text-sm text-gray-400","children":[["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar h-4 w-4","aria-hidden":"true","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-13","children":"13/3/2026"}]]}],["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock h-4 w-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","span",null,{"children":"6 min"}]]}]]}]]}],["$","div",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"mb-10 rounded-2xl border border-secondary/20 bg-secondary/10 p-6","children":[["$","h2",null,{"className":"mb-4 text-2xl font-bold text-white","children":"Snel overzicht"}],["$","ul",null,{"className":"space-y-2 text-gray-300","children":[["$","li","Enkel crepi (zonder isolatie): gemiddeld €40–€70 per m²",{"children":["• ","Enkel crepi (zonder isolatie): gemiddeld €40–€70 per m²"]}],"$L3","$L4","$L5"]}]]}],["$L6","$L7","$L8","$L9","$La"],"$Lb"]}],"$Lc"]}]}]}]],null,"$Ld"]}],"loading":null,"isPartial":false}
