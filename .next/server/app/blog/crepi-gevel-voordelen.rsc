1c:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.yannova.be/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://www.yannova.be/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Crepi gevel voordelen: wanneer is crepi de juiste keuze?\",\"item\":\"https://www.yannova.be/blog/crepi-gevel-voordelen\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Crepi gevel voordelen: wanneer is crepi de juiste keuze?\",\"description\":\"Ontdek de voordelen van een crepi gevel. Wanneer is crepi slim, hoe combineert u het met isolatie en waar moet u op letten bij afwerking en onderhoud?\",\"image\":\"https://www.yannova.be/og-image.jpg\",\"datePublished\":\"2026-03-12\",\"dateModified\":\"2026-03-12\",\"author\":{\"@type\":\"Organization\",\"name\":\"Yannova\",\"url\":\"https://www.yannova.be\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Yannova Bouw\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.yannova.be/logo.png\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.yannova.be/blog/crepi-gevel-voordelen\"}}"}}],["$","div",null,{"className":"min-h-screen bg-[#0a0c10]","children":["$","article",null,{"className":"py-20","children":["$","div",null,{"className":"container mx-auto max-w-4xl px-6","children":[["$","$L12",null,{"href":"/blog","className":"mb-8 inline-flex items-center gap-2 text-secondary hover:underline","children":"← Terug naar blog"}],["$","header",null,{"className":"mb-12","children":[["$","div",null,{"className":"mb-4 inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-secondary","children":"Advies"}],["$","h1",null,{"className":"text-4xl font-bold text-white sm:text-5xl","children":"Crepi gevel voordelen: wanneer is crepi de juiste keuze?"}],["$","p",null,{"className":"mt-6 text-xl leading-relaxed text-gray-300","children":"Crepi is populair omdat het tegelijk een esthetische en technische oplossing kan zijn. U geeft uw woning een nieuwe uitstraling, en als u crepi combineert met buitenisolatie verbetert u ook de energieprestatie van de gevel."}],["$","div",null,{"className":"mt-6 flex items-center gap-4 text-sm text-gray-400","children":[["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-calendar h-4 w-4","aria-hidden":"true","children":[["$","path","1cmpym",{"d":"M8 2v4"}],["$","path","4m81vk",{"d":"M16 2v4"}],["$","rect","1hopcy",{"width":"18","height":"18","x":"3","y":"4","rx":"2"}],["$","path","8toen8",{"d":"M3 10h18"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-12","children":"12/3/2026"}]]}],["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock h-4 w-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","span",null,{"children":"6 min"}]]}]]}]]}],["$","div",null,{"className":"prose prose-invert prose-lg max-w-none","children":[["$","div",null,{"className":"mb-10 rounded-2xl border border-secondary/20 bg-secondary/10 p-6","children":[["$","h2",null,{"className":"mb-4 text-2xl font-bold text-white","children":"Snel overzicht"}],["$","ul",null,{"className":"space-y-2 text-gray-300","children":[["$","li","Crepi geeft een bestaande woning snel een strakke, hedendaagse uitstraling",{"children":["• ","Crepi geeft een bestaande woning snel een strakke, hedendaagse uitstraling"]}],"$L24","$L25","$L26"]}]]}],["$L27","$L28","$L29","$L2a","$L2b"],"$L2c"]}],"$L2d"]}]}]}]]
24:["$","li","De afwerking combineert goed met buitenisolatie",{"children":["• ","De afwerking combineert goed met buitenisolatie"]}]
