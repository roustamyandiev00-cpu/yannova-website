2:Tbc8,[{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Bart & Sofie V."},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"Yannova heeft onze gevel volledig gerenoveerd met crepi. Het resultaat is verbluffend! Zeer propere afwerking en alles volgens afspraak. De communicatie was uitstekend en ze hielden zich perfect aan de planning.","datePublished":"2025-11"},{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Tom J."},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"Nieuwe ramen laten plaatsen. Het advies was eerlijk en de plaatsers werkten zeer nauwkeurig. Een absolute aanrader voor wie kwaliteit zoekt. De isolatie is merkbaar verbeterd!","datePublished":"2025-10"},{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Familie Peeters"},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"We zochten een aannemer voor onze totaalrenovatie en kwamen bij Yannova terecht. Eén aanspreekpunt voor alles was een enorme geruststelling. Professioneel werk van A tot Z.","datePublished":"2025-09"},{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Linda M."},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"Gevelisolatie laten aanbrengen. Zeer tevreden over het resultaat. Het huis is nu veel warmer en onze energiefactuur is merkbaar gedaald. Aanrader!","datePublished":"2025-08"},{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Marc D."},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"Snelle service, correcte prijs en kwaliteitsvol werk. De nieuwe ramen zijn prachtig en perfect geplaatst. Geen rommel achtergelaten, alles netjes opgeruimd.","datePublished":"2025-07"},{"@context":"https://schema.org","@type":"Review","itemReviewed":{"@type":"LocalBusiness","name":"Yannova Bouw","@id":"https://www.yannova.be/#organization"},"author":{"@type":"Person","name":"Sarah & Kevin"},"reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":"5","worstRating":"1"},"reviewBody":"Onze gevel ziet er weer als nieuw uit! Yannova heeft ons goed geadviseerd over de beste oplossing. Het team was vriendelijk en professioneel. Top!","datePublished":"2025-06"}]0:{"buildId":"Ei9X_LlIG6mhE8TS9VthO","rsc":["$","$1","c",{"children":[["$","div",null,{"className":"py-24 sm:py-32 bg-background relative overflow-hidden","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4","$L5"]}],["$L6"],"$L7"]}],"loading":null,"isPartial":false}
