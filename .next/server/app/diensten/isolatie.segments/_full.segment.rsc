1f:["$","div",null,{"className":"space-y-6 text-muted-foreground text-lg","children":[["$","p",null,{"children":"Isolatie is vaak de snelste weg naar een lagere energiefactuur, maar alleen als u de juiste zone aanpakt. Daarom bekijken we niet alleen het materiaal, maar de volledige woning: dak, buitenmuren, vloer, ramen en aansluitingen."}],["$","p",null,{"children":["Yannova voert isolatiewerken uit in Zoersel, Antwerpen en omliggende gemeenten. We adviseren wanneer dakisolatie, spouwmuurisolatie, buitengevelisolatie of vloerisolatie het meeste effect geeft en wanneer een combinatie met ",["$","$L12",null,{"href":"/diensten/gevelrenovatie","className":"text-secondary hover:underline","children":"gevelrenovatie"}]," of ",["$","$L12",null,{"href":"/diensten/ramen-deuren","className":"text-secondary hover:underline","children":"nieuwe ramen"}]," slimmer is."]}],["$","p",null,{"children":["Wie ook premies of een betere EPC-score wil meenemen, kan zich vooraf verdiepen in onze ",["$","$L12",null,{"href":"/premie-gids","className":"text-secondary hover:underline","children":"premie-gids"}],". Tijdens het traject helpen we u praktisch vooruit met duidelijke keuzes en een realistische offerte."]}]]}]
