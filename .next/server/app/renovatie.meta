{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/renovatie/layout,_N_T_/renovatie/page,_N_T_/renovatie"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/renovatie/__PAGE__",
    "/renovatie",
    "/_index",
    "/_head"
  ]
}