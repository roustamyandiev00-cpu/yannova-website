{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/wijnegem/layout,_N_T_/wijnegem/page,_N_T_/wijnegem"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/wijnegem/__PAGE__",
    "/wijnegem",
    "/_index",
    "/_head"
  ]
}