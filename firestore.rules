rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Chat sessions - allow read/write for all users
    match /chatSessions/{sessionId} {
      allow read, write: if true;
    }
    
    // Chat messages - allow read/write for all users
    match /chatMessages/{messageId} {
      allow read, write: if true;
    }
    
    // Chat automation configuration - allow read/write for all users
    match /chatAutomation/{document} {
      allow read, write: if true;
    }
    
    // Admin settings - allow read/write for all users
    match /adminSettings/{document} {
      allow read, write: if true;
    }
    
    // Auto replies configuration - allow read/write for all users
    match /autoReplies/{document} {
      allow read, write: if true;
    }
    
    // Leads - allow read/write for all users (for contact forms)
    match /leads/{leadId} {
      allow read, write: if true;
    }
    
    // Test collection - allow read/write for all users
    match /test/{document} {
      allow read, write: if true;
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}