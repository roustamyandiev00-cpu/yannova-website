# Copy this file to .env.local and fill in the real values
# .env.local is gitignored and will not be committed to version control

# ============================================
# Email Configuration
# ============================================
# Get SMTP credentials from your email hosting provider
SMTP_HOST=mail.b.hostedemail.com
SMTP_PORT=465
SMTP_USER=info@yannova.be
SMTP_PASS=<your-smtp-password-here>

# ============================================
# NextAuth Configuration
# ============================================
# Generate a secure random string with: openssl rand -base64 32
AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# For local development, use localhost
# For production, set to your production domain
AUTH_URL=http://localhost:3000

# ============================================
# Database - Supabase PostgreSQL
# ============================================
# Get database credentials from Supabase dashboard
# Format: postgresql://postgres:<PASSWORD>@<HOST>:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:<YOUR_PASSWORD>@db.nnlekbywldrainqhvgif.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:<YOUR_PASSWORD>@db.nnlekbywldrainqhvgif.supabase.co:5432/postgres?schema=public"

# ============================================
# Google AI & Analytics
# ============================================
# Google Analytics ID (public - can be in .env)
NEXT_PUBLIC_GA_ID=G-1RS27QF82W

# Get Google AI API key from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_GENERATIVE_AI_API_KEY=<your-google-ai-api-key-here>

# ============================================
# Supabase (optional - for file storage)
# ============================================
# Get these keys from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://nnlekbywldrainqhvgif.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key-here>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key-here>

# ============================================
# Site Configuration
# ============================================
# For local development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# For production deployment (set in Vercel environment variables)
# NEXT_PUBLIC_SITE_URL=https://www.yannova.be

# ============================================
# Contact Email (optional)
# ============================================
# Email address where contact form submissions are sent
CONTACT_EMAIL=info@yannova.be

# ============================================
# Microsoft Clarity Analytics
# ============================================
# Get your Clarity ID from https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=<your-clarity-project-id>

# Clarity API Token for Data Export
# Get from Clarity Dashboard > Settings > Data Export > Generate API Token
CLARITY_API_TOKEN=<your-clarity-api-token>
CLARITY_PROJECT_ID=<your-clarity-project-id>
