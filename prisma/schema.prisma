generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("user") // "admin", "super_admin", "editor", "user"
  active    Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  activities ActivityLog[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // e.g., "ramen-deuren", "gevelrenovatie", "totaalrenovatie"
  imageUrl    String
  location    String?  // e.g., "Zoersel", "Antwerpen", "Mechelen"
  material    String?  // e.g., "PVC", "Aluminium", "Crepi"
  year        Int?     // Year of completion
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  phone     String?
  message   String
  source    String   @default("chatbot") // "chatbot" of "contact-form"
  read      Boolean  @default(false)
  archived  Boolean  @default(false)
  priority  String   @default("normal") // "low", "normal", "high"
  notes     String?
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  rating    Int      @default(5) // 1-5 stars
  text      String
  imageUrl  String?
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   // "general", "contact", "social", "seo", "email"
  description String?
  updatedAt   DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int      // in bytes
  mimeType  String
  folder    String   @default("uploads")
  alt       String?
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model SeoPage {
  id          String   @id @default(cuid())
  path        String   @unique // e.g., "/", "/diensten", "/projecten"
  title       String   // Meta title
  description String   // Meta description
  keywords    String?  // Meta keywords (comma separated)
  ogImage     String?  // Open Graph image URL
  ogTitle     String?  // Open Graph title (optional override)
  ogDescription String? // Open Graph description (optional override)
  canonicalUrl String?  // Canonical URL override
  h1          String?  // H1 heading content
  noindex     Boolean  @default(false)
  nofollow    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([path])
}

model SeoAudit {
  id          String   @id @default(cuid())
  path        String
  issue       String   // e.g., "missing_title", "missing_description", "duplicate_h1"
  severity    String   // "error", "warning", "info"
  message     String
  fixed       Boolean  @default(false)
  createdAt   DateTime @default(now())
  fixedAt     DateTime?

  @@index([path])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "create", "update", "delete", "login"
  entity    String   // "project", "lead", "testimonial", etc.
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Google Ads Tracking
model GoogleAdsKeyword {
  id              String   @id @default(cuid())
  keyword         String
  matchType       String   // "exact", "phrase", "broad"
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  cost            Float    @default(0)
  ctr             Float    @default(0) // Click-through rate
  cpc             Float    @default(0) // Cost per click
  conversionRate  Float    @default(0)
  qualityScore    Int?     // 1-10
  status          String   @default("active") // "active", "paused", "removed"
  campaign        String?
  adGroup         String?
  period          DateTime // Date for this data point
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([keyword])
  @@index([period])
  @@index([campaign])
}

model GoogleAdsCampaign {
  id              String   @id @default(cuid())
  name            String
  budget          Float
  spent           Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  ctr             Float    @default(0)
  conversionRate  Float    @default(0)
  status          String   @default("active")
  startDate       DateTime
  endDate         DateTime?
  period          DateTime // Date for this data point
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([period])
}

// Performance Metrics
model PerformanceMetric {
  id          String   @id @default(cuid())
  metric      String   // "page_speed", "seo_score", "conversion_rate", "bounce_rate"
  value       Float
  previousValue Float?
  improvement Float?   // Percentage improvement
  category    String   // "seo", "performance", "conversion", "user_experience"
  page        String?  // Specific page if applicable
  period      DateTime // Date for this metric
  notes       String?
  createdAt   DateTime @default(now())

  @@index([metric])
  @@index([period])
  @@index([category])
}

// SEO Rankings
model SeoRanking {
  id          String   @id @default(cuid())
  keyword     String
  position    Int
  previousPosition Int?
  url         String
  searchEngine String  @default("google") // "google", "bing"
  location    String  @default("Belgium") // Geographic location
  device      String  @default("desktop") // "desktop", "mobile"
  searchVolume Int?
  difficulty  Int?    // 1-100
  period      DateTime
  createdAt   DateTime @default(now())

  @@index([keyword])
  @@index([period])
  @@index([position])
}

// Conversion Tracking
model Conversion {
  id          String   @id @default(cuid())
  type        String   // "lead", "call", "form", "chat"
  source      String   // "google_ads", "organic", "direct", "referral"
  campaign    String?
  keyword     String?
  value       Float?   // Estimated value
  leadId      String?
  page        String?  // Landing page
  device      String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([source])
  @@index([createdAt])
}

// Traffic Analytics
model TrafficAnalytics {
  id              String   @id @default(cuid())
  date            DateTime @unique
  pageViews       Int      @default(0)
  uniqueVisitors  Int      @default(0)
  bounceRate      Float    @default(0)
  avgSessionTime  Int      @default(0) // in seconds
  newVisitors     Int      @default(0)
  returningVisitors Int    @default(0)
  topPages        String?  // JSON array of top pages
  topSources      String?  // JSON array of traffic sources
  deviceBreakdown String?  // JSON object with device stats
  createdAt       DateTime @default(now())

  @@index([date])
}